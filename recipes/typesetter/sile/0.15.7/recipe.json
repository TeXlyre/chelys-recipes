{
    "id": "sile",
    "type": "typesetter",
    "name": "SILE",
    "iconUrl": "https://texlyre.github.io/chelys-recipes/recipes/typesetter/sile/icon.png",
    "description": "The SILE typesetting engine. Compiles .sil documents to PDF over a local WebSocket compile bridge.",
    "notes": "SILE runs inside a Docker container alongside the shared Chelys typesetter bridge (ghcr.io/texlyre/chelys-typeset-bridge:1), which implements the TeXlyre compile protocol: it receives project files over a WebSocket, runs sile via the ENGINE_* variables, and returns the compiled PDF. Docker mode is recommended. The bridge keeps a per-connection working tree and reconciles it against the manifest TeXlyre sends, so only changed files travel after the first compile. When options.action is 'clear-cache' the tree is wiped and status 0 returned without compiling. When options.export is true the output bytes are returned for download; other option keys (e.g. includeLog) are passed through from the recipe UI schema.",
    "tags": [
        "sile",
        "typesetting",
        "pdf"
    ],
    "author": "TeXlyre",
    "version": "0.15.7",
    "lastUpdated": "2026-07-15T10:00:00Z",
    "variables": [
        {
            "key": "wsPort",
            "label": "WebSocket port",
            "kind": "number",
            "default": "7040",
            "help": "Port the compile bridge listens on."
        }
    ],
    "env": {},
    "modes": [
        {
            "kind": "docker",
            "image": "chelys/sile:local",
            "dockerfileUrl": "https://texlyre.github.io/chelys-recipes/recipes/typesetter/sile/0.15.7/Dockerfile",
            "buildSteps": [],
            "runArgs": [
                "-p",
                "${wsPort}:${wsPort}",
                "-e",
                "WS_PORT=${wsPort}"
            ]
        },
        {
            "kind": "connect"
        }
    ],
    "typeConfig": {
        "configId": "sile",
        "projectType": "sile",
        "inputExtensions": [
            "sil"
        ],
        "inputFiles": [
            {
                "extension": "sil",
                "label": {
                    "key": "{typesetter} File",
                    "params": {
                        "typesetter": "SILE"
                    }
                },
                "mimeType": "application/x-sile"
            }
        ],
        "outputFormats": [
            {
                "id": "pdf",
                "mimeType": "application/pdf",
                "rendererPluginId": "pdf-renderer"
            },
            {
                "id": "canvas-pdf",
                "mimeType": "application/pdf",
                "rendererPluginId": "canvas-renderer",
                "outputType": "canvas"
            }
        ],
        "transportType": "websocket",
        "transportUrl": "ws://localhost:${wsPort}",
        "incrementalSync": true,
        "formatter": "",
        "hasOutline": false,
        "ui": {
            "compile": {
                "fields": [
                    {
                        "key": "format",
                        "label": "Output Format:",
                        "kind": "select",
                        "sendAs": "format",
                        "defaultValue": "pdf",
                        "options": [
                            {
                                "label": "PDF",
                                "value": "pdf"
                            },
                            {
                                "label": "Canvas (PDF)",
                                "value": "canvas-pdf"
                            }
                        ]
                    }
                ]
            },
            "export": {
                "label": "Export",
                "fields": [
                    {
                        "key": "format",
                        "label": "Export Format:",
                        "kind": "select",
                        "sendAs": "format",
                        "defaultValue": "pdf",
                        "options": [
                            {
                                "label": "PDF",
                                "value": "pdf"
                            }
                        ]
                    },
                    {
                        "key": "includeLog",
                        "label": {
                            "key": "Include log file"
                        },
                        "kind": "boolean",
                        "defaultValue": false,
                        "sendAs": "option"
                    }
                ]
            },
            "renderers": [
                {
                    "format": "pdf",
                    "label": "PDF"
                },
                {
                    "format": "canvas-pdf",
                    "label": "Canvas (PDF)"
                }
            ],
            "info": {
                "title": "SILE",
                "rows": [
                    {
                        "label": {
                            "key": "{typesetter} Engine:",
                            "params": {
                                "typesetter": "SILE"
                            }
                        },
                        "value": {
                            "key": "SILE v0.15.7"
                        }
                    },
                    {
                        "label": {
                            "key": "Transport Protocol:"
                        },
                        "value": {
                            "key": "WebSocket compile bridge"
                        }
                    },
                    {
                        "label": {
                            "key": "Input Format:"
                        },
                        "value": {
                            "key": "SIL (.sil)"
                        }
                    },
                    {
                        "label": {
                            "key": "Output Formats:"
                        },
                        "value": {
                            "key": "PDF, Canvas (PDF)"
                        }
                    }
                ]
            }
        }
    }
}
